    "note":    { "profile": "rak", "identity": "owned",   "mutation": "mutable",     "ext": null },
    "thread":  { "profile": "rak", "identity": "owned",   "mutation": "mutable",     "ext": null },
    "podcast": { "profile": "rak", "identity": "owned",   "mutation": "mutable",     "ext": null },
    "image":   { "profile": "rak", "identity": "owned",   "mutation": "mutable",     "ext": null },
    "video":   { "profile": "rak", "identity": "owned",   "mutation": "mutable",     "ext": null },
    "dataset": { "profile": "rak", "identity": "owned",   "mutation": "mutable",     "ext": null },
    "review":  { "profile": "fop", "identity": "subject", "mutation": "append-only", "ext": "kinds/review.ext.schema.json" },
    "listing": { "profile": "fop", "identity": "owned",   "mutation": "append-only", "ext": "kinds/listing.ext.schema.json" },
