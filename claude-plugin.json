{
  "name": "rak-mcp",
  "displayName": "RAK — Polish local content + AI editorial",
  "version": "0.1.0",
  "description": "Instant access to Kanał ZERO / RAK.AD content (articles, wire, per-region feeds, 1709 sources) and editorial tools (research, writing, media, QA) over MCP.",
  "homepage": "https://rak.ad",
  "categories": ["news", "content", "research", "poland", "media"],
  "keywords": ["poland", "news", "local media", "rag", "journalism", "regions"],
  "mcpServers": {
    "rak": {
      "command": "npx",
      "args": ["-y", "@rak/mcp"],
      "env": {
        "RAK_API_KEY": "${RAK_API_KEY}",
        "RAK_BASE_URL": "https://rak.ad",
        "RAK_TENANT_ID": "rak"
      }
    }
  },
  "remote": {
    "url": "https://rak.ad/api/mcp/rak/mcp",
    "authorization": "Bearer ${RAK_API_KEY}",
    "headers": { "Api-Version": "2026-05" }
  },
  "tiers": ["anon", "free", "paid", "partner", "internal"]
}
