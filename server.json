{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-09-29/server.schema.json",
  "name": "ad.rak/rak-mcp",
  "description": "Polish local news + AI editorial tools: hybrid search, wire feed, per-region feeds (16 regions), 1709 sources, research/writing/media/QA.",
  "version": "0.2.0",
  "repository": {
    "url": "https://github.com/Hei33enberg/rak-mcp",
    "source": "github"
  },
  "websiteUrl": "https://rak.ad",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@rak-ad/mcp",
      "version": "0.2.0",
      "transport": { "type": "stdio" },
      "environmentVariables": [
        { "name": "RAK_API_KEY", "description": "Bearer key (omit for anonymous access)", "isRequired": false, "isSecret": true },
        { "name": "RAK_BASE_URL", "description": "RAK node base URL", "isRequired": false, "default": "https://rak.ad" },
        { "name": "RAK_TENANT_ID", "description": "Tenant", "isRequired": false, "default": "rak" }
      ]
    }
  ],
  "remotes": [
    { "type": "streamable-http", "url": "https://rak.ad/api/mcp/rak/mcp" }
  ]
}
